<%- include('../partials/header') %>

<section class="admin-page">
  <div class="admin-hero">
    <h1>Admin Dashboard</h1>
    <p>Manage products, orders, categories and homepage banners.</p>
  </div>

  <div class="admin-stats">
    <a href="/admin/analytics" class="admin-stat-card">
  <span>📈</span>
  <h2>Analytics</h2>
  <p>Sales & Revenue</p>
</a>
    <a href="/admin/products" class="admin-stat-card">
      <span>📦</span>
      <h2><%= stats.products %></h2>
      <p>Products</p>
    </a>

    <a href="/admin/orders" class="admin-stat-card">
      <span>🧾</span>
      <h2><%= stats.orders %></h2>
      <p>Orders</p>
    </a>

    <div class="admin-stat-card">
      <span>👥</span>
      <h2><%= stats.customers %></h2>
      <p>Customers</p>
    </div>
  </div>

  <div class="admin-actions">
    <a href="/admin/orders">View Customer Orders</a>
    <a href="/admin/products">Manage Products</a>
    <a href="/admin/products/new">Add Product</a>
    <a href="/admin/categories">Manage Categories</a>
    <a href="/customer">Customer View</a>
  </div>
</section>


<div class="admin-chart-card small-chart">
  <h2>Store Statistics</h2>

  <div class="chart-wrapper">
    <canvas id="adminStatsChart"></canvas>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const ctx = document.getElementById('adminStatsChart');

  new Chart(ctx, {
    type: 'bar',

    data: {
      labels: ['Products', 'Orders', 'Customers'],

      datasets: [{
        label: 'Store Data',

        data: [
          <%= stats.products %>,
          <%= stats.orders %>,
          <%= stats.customers %>
        ],

        backgroundColor: [
          '#0b8f4d',
          '#ffc107',
          '#00c2ff'
        ],

        borderRadius: 12,
        borderSkipped: false
      }]
    },

    options: {
      responsive: true,
      maintainAspectRatio: false,

      plugins: {
        legend: {
          display: false
        }
      },

      scales: {
        y: {
          beginAtZero: true,

          ticks: {
            color: '#ffffff'
          },

          grid: {
            color: 'rgba(255,255,255,0.08)'
          }
        },

        x: {
          ticks: {
            color: '#ffffff'
          },

          grid: {
            display: false
          }
        }
      }
    }
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  new Chart(document.getElementById('adminStatsChart'), {
    type: 'bar',
    data: {
      labels: ['Products', 'Orders', 'Customers'],
      datasets: [{
        label: 'Count',
        data: [
          <%= stats.products %>,
          <%= stats.orders %>,
          <%= stats.customers %>
        ]
      }]
    }
  });
</script>
<%- include('../partials/footer') %>