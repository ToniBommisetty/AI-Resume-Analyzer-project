<%- include('../partials/header') %>

<section class="customer-account-page">
  <div class="customer-hero">
    <div>
      <span class="welcome-badge">
        <%= user.role === 'admin' ? 'Admin Overview' : 'Customer Dashboard' %>
      </span>

      <h1>Welcome, <%= user.name %></h1>

      <% if (user.role === 'admin') { %>
        <p>Manage products, customer orders, categories, and store settings.</p>
      <% } else { %>
        <p>Shop products, manage your basket, checkout, and view your order history.</p>
      <% } %>
    </div>

    <% if (user.role === 'admin') { %>
      <a href="/admin">Go to Admin Panel</a>
    <% } else { %>
      <a href="/products">Start Shopping</a>
    <% } %>
  </div>

  <div class="customer-actions">
    <% if (user.role === 'admin') { %>

      <a href="/admin/products" class="customer-action-card">
        <span>📦</span>
        <h2>Products</h2>
        <p>Manage store products</p>
      </a>

      <a href="/admin/orders" class="customer-action-card">
        <span>🧾</span>
        <h2>Orders</h2>
        <p>Manage customer orders</p>
      </a>

      <a href="/admin/categories" class="customer-action-card">
        <span>📂</span>
        <h2>Categories</h2>
        <p>Manage categories</p>
      </a>

    <% } else { %>

      <a href="/products" class="customer-action-card">
        <span>🛒</span>
        <h2>Shop</h2>
        <p>Browse wholesale products</p>
      </a>

      <a href="/cart" class="customer-action-card">
        <span>🧺</span>
        <h2>Basket</h2>
        <p>View your selected items</p>
      </a>

      <a href="/account/orders" class="customer-action-card">
        <span>🧾</span>
        <h2>Orders</h2>
        <p>Track your order history</p>
      </a>

    <% } %>
  </div>

  <% if (user.role !== 'admin') { %>
    <div class="dashboard-section">
      <div class="section-title-row">
        <h2>Recent Orders</h2>
        <a href="/account/orders">View all</a>
      </div>

      <% if (recentOrders.length) { %>
        <div class="orders-card mini-orders-card">
          <table class="orders-table">
            <thead>
              <tr>
                <th>Order</th>
                <th>Total</th>
                <th>Status</th>
                <th>Date</th>
              </tr>
            </thead>

            <tbody>
              <% recentOrders.forEach(order => { %>
                <tr>
                  <td><strong>#<%= order.id %></strong></td>
                  <td>£<%= Number(order.total).toFixed(2) %></td>
                  <td><span class="customer-status"><%= order.status %></span></td>
                  <td><%= order.created_at %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-customer-card">
          <span>📦</span>
          <h3>No orders yet</h3>
          <p>Your recent orders will appear here after checkout.</p>
          <a href="/products">Shop Now</a>
        </div>
      <% } %>
    </div>

    <div class="dashboard-section">
      <div class="section-title-row">
        <h2>Featured Products</h2>
        <a href="/products">View all</a>
      </div>

      <div class="customer-products-grid">
        <% featuredProducts.forEach(product => { %>
          <article class="customer-product-card">
            <a href="/product/<%= product.slug %>">
              <img src="<%= product.image || '/images/placeholder-product.svg' %>" alt="<%= product.name %>">

              <div class="customer-product-info">
                <p><%= product.brand || product.category_name || 'Navtej Wholesale' %></p>
                <h3><%= product.name %></h3>
                <strong>£<%= Number(product.price).toFixed(2) %></strong>
              </div>
            </a>

            <form method="post" action="/cart/add/<%= product.id %>">
              <input type="hidden" name="qty" value="1">
              <button type="submit">+ Add to Basket</button>
            </form>
          </article>
        <% }) %>
      </div>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>