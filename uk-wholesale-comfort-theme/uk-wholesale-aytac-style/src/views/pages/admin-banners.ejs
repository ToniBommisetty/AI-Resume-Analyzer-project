<%- include('../partials/header') %><section class="section"><%- include('../partials/admin-nav') %><h1>Homepage Banners</h1><form class="admin-form vertical" method="post" action="/admin/banners" enctype="multipart/form-data"><input name="title" placeholder="Banner title" required><input name="subtitle" placeholder="Subtitle"><input name="button_text" placeholder="Button text"><input name="button_link" placeholder="/products"><input name="sort_order" type="number" placeholder="Sort order"><label>Upload banner image<input name="image_file" type="file" accept="image/*"></label><label><input type="checkbox" name="is_active" checked> Active</label><button class="btn">Add Banner</button></form><table class="cart-table"><tr><th>Image</th><th>Title</th><th></th></tr><% banners.forEach(b => { %><tr><td><img class="thumb" src="<%= b.image %>"></td><td><%= b.title %></td><td><form method="post" action="/admin/banners/<%= b.id %>?_method=DELETE"><button>Delete</button></form></td></tr><% }) %></table></section><%- include('../partials/footer') %>