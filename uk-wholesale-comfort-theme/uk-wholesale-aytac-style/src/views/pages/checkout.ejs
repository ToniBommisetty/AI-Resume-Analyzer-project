<%- include('../partials/header') %>

<section class="checkout-page">
  <div class="checkout-header">
    <h1>Checkout</h1>
    <p>Confirm your delivery details before placing your order.</p>
  </div>

  <% if (error) { %>
    <p class="error"><%= error %></p>
  <% } %>

  <div class="checkout-grid">
    <form method="post" action="/checkout" class="checkout-card">
      <h2>Delivery Details</h2>

      <label>Delivery Address</label>
      <textarea name="delivery_address" rows="5" required placeholder="Enter full delivery address"></textarea>

      <label>Order Notes</label>
      <textarea name="notes" rows="4" placeholder="Any delivery notes?"></textarea>

      <div class="payment-note">
  <h3>Payment Method</h3>
  <p>Payment can be completed by bank transfer or pay on delivery after order confirmation.</p>
</div>

    <div class="collection-box">
  <h3>How would you like to receive your order?</h3>

  <label>
    <input type="radio" name="fulfillment_method" value="delivery" checked onchange="toggleCollection(false)">
    Delivery to my address
  </label>

  <label>
    <input type="radio" name="fulfillment_method" value="collection" onchange="toggleCollection(true)">
    Collect from store
  </label>

  <div id="collectionBranches" class="collection-branches" style="display:none;">
    <p>Select your nearest Navtej branch:</p>

    <select name="collection_branch">
      <option value="">Choose branch</option>
      <option value="London Branch - Ealing">London Branch - Ealing</option>
      <option value="London Branch - Tottenham">London Branch - Tottenham</option>
      <option value="Birmingham Branch">Birmingham Branch</option>
      <option value="Manchester Branch">Manchester Branch</option>
      <option value="Leicester Branch">Leicester Branch</option>
      <option value="Liverpool Branch">Liverpool Branch</option>
      <option value="Glasgow Branch">Glasgow Branch</option>
    </select>

    <button type="button" class="nearest-btn" onclick="findNearestBranch()">
      📍 Find nearest branch
    </button>

    <p id="nearestBranchText" class="nearest-result"></p>
  </div>
</div>

<script>
  function toggleCollection(show) {
    document.getElementById('collectionBranches').style.display = show ? 'block' : 'none';
  }

  function findNearestBranch() {
    const output = document.getElementById('nearestBranchText');

    if (!navigator.geolocation) {
      output.textContent = 'Location is not supported by your browser.';
      return;
    }

    output.textContent = 'Checking your location...';

    const branches = [
      { name: 'London Branch - Ealing', lat: 51.5130, lng: -0.3089 },
      { name: 'London Branch - Tottenham', lat: 51.5880, lng: -0.0720 },
      { name: 'Birmingham Branch', lat: 52.4862, lng: -1.8904 },
      { name: 'Manchester Branch', lat: 53.4808, lng: -2.2426 },
      { name: 'Leicester Branch', lat: 52.6369, lng: -1.1398 },
      { name: 'Liverpool Branch', lat: 53.4084, lng: -2.9916 },
      { name: 'Glasgow Branch', lat: 55.8642, lng: -4.2518 }
    ];

    navigator.geolocation.getCurrentPosition(pos => {
      const userLat = pos.coords.latitude;
      const userLng = pos.coords.longitude;

      function distance(lat1, lng1, lat2, lng2) {
        const R = 6371;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLng = (lng2 - lng1) * Math.PI / 180;
        const a =
          Math.sin(dLat / 2) * Math.sin(dLat / 2) +
          Math.cos(lat1 * Math.PI / 180) *
          Math.cos(lat2 * Math.PI / 180) *
          Math.sin(dLng / 2) *
          Math.sin(dLng / 2);

        return R * (2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a)));
      }

      let nearest = branches[0];
      let nearestDistance = distance(userLat, userLng, nearest.lat, nearest.lng);

      branches.forEach(branch => {
        const d = distance(userLat, userLng, branch.lat, branch.lng);

        if (d < nearestDistance) {
          nearest = branch;
          nearestDistance = d;
        }
      });

      document.querySelector('select[name="collection_branch"]').value = nearest.name;
      output.textContent = `Nearest branch: ${nearest.name} (${nearestDistance.toFixed(1)} km away)`;
    }, () => {
      output.textContent = 'Unable to access location. Please select branch manually.';
    });
  }
</script>

    <div class="payment-method-box">
  <h3>Payment Method</h3>

  <label>
    <input type="radio" name="payment_method" value="pay_on_delivery" checked>
    Pay on Delivery / Bank Transfer
  </label>

  <label>
    <input type="radio" name="payment_method" value="card">
    Pay by Card
  </label>
</div>
      <button type="submit">Place Order</button>
    </form>

    <div class="checkout-card">
      <h2>Order Summary</h2>

      <% cart.forEach(item => { %>
        <div class="summary-row">
          <span><%= item.name %> × <%= item.qty %></span>
          <strong>£<%= Number(item.price * item.qty).toFixed(2) %></strong>
        </div>
      <% }) %>

      <div class="summary-total">
        <span>Total</span>
        <strong>£<%= Number(total).toFixed(2) %></strong>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>