pipeline {
    agent any

    tools {
        nodejs "NodeJS"
    }

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/ToniBommisetty/ToniWholeSale.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Test') {
            steps {
                echo 'No tests defined yet'
            }
        }

        stage('Deploy (PM2)') {
            steps {
                bat 'npx pm2 delete uk-wholesale || exit 0'
                bat 'npx pm2 start server.js --name uk-wholesale'
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }
        failure {
            echo 'Deployment Failed'
        }
    }
}