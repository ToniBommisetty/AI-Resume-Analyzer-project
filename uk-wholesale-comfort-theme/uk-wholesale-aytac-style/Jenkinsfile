pipeline {
    agent any

    tools {
        nodejs "NodeJS"
    }

    stages {

        stage('Checkout') {
            steps {
                git 'https://github.com/ToniBommisetty/ToniWholeSale.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Test') {
            steps {
                echo 'No tests defined yet'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Starting application using Node (no PM2)'
                
                // Kill any old node process (prevents port issues)
                bat 'taskkill /F /IM node.exe || exit 0'

                // Start server
                bat 'start /B node server.js'
            }
        }
    }

    post {
        success {
            echo 'Deployment Successful'
        }

        failure {
            echo 'Deployment Failed'
        }
    }
}